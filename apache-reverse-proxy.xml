  <Config Name="EMAIL" Target="EMAIL" Default="admin@example.com" Mode="" Description="Email for Let's Encrypt (REQUIRED)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="" Mode="" Description="For AUTHTYPE=basic. Format: user1:pass1|user2:pass2" Type="Variable" Display="always" Required="false" Mask="true"/>

  <!-- ENTRA ID (MICROSOFT) -->
