  <Config Name="Dashboard Order" Target="DASHBOARD_ORDER" Default="DOWNLOADS,INFRA,MEDIA" Mode="" Description="Service group display order. Categories: DOWNLOADS (SABnzbd, NZBGet, NZBHydra, Deluge, Transmission, qBittorrent), INFRA (Radarr, Sonarr, Prowlarr, Seerr, Lidarr, Whisparr), MEDIA (Emby, Plex, Jellyfin, Tautulli). Example: MEDIA,DOWNLOADS,INFRA" Type="Variable" Display="always" Required="false" Mask="false"/>
  
