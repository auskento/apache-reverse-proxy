<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>Apache-Reverse-Proxy</Name>
  <Repository>auskento/apache-reverse-proxy:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/apache-reverse-proxy</Support>
  <Project>https://github.com/auskento/apache-reverse-proxy</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/apache-reverse-proxy/main/apache-reverse-proxy.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/apache-reverse-proxy/main/apache-reverse-proxy-150.png</Icon>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>Apache Reverse Proxy with Let's Encrypt HTTPS and modular service proxying.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/apache-reverse-proxy/html</HostDir>
      <ContainerDir>/var/www/html</ContainerDir>
      <Mode>rw</Mode>
      <Description>HTML Dashboard</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>
  
  <!-- ENVIRONMENT VARIABLES - These get passed to the container -->
  <Environment>
    <Variable>
      <Name>DOMAIN</Name>
      <Value>yourdomain.com</Value>
    </Variable>
    <Variable>
      <Name>EMAIL</Name>
      <Value>admin@example.com</Value>
    </Variable>
    <Variable>
      <Name>TZ</Name>
      <Value>Australia/Melbourne</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_SONARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SONARR_URL</Name>
      <Value>http://sonarr:8989</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_SONARR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_RADARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>RADARR_URL</Name>
      <Value>http://radarr:7878</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_RADARR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_WHISPARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>WHISPARR_URL</Name>
      <Value>http://whisparr:6969</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_WHISPARR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_JELLYFIN</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>JELLYFIN_URL</Name>
      <Value>http://jellyfin:8096</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_JELLYFIN</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_LIDARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>LIDARR_URL</Name>
      <Value>http://lidarr:8686</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_LIDARR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_READARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>READARR_URL</Name>
      <Value>http://readarr:8787</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_READARR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_PROWLARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PROWLARR_URL</Name>
      <Value>http://prowlarr:9696</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_PROWLARR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_OVERSEERR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>OVERSEERR_URL</Name>
      <Value>http://overseerr:5055</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_OVERSEERR</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_EMBY</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>EMBY_URL</Name>
      <Value>http://emby:8096</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_EMBY</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_PLEX</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PLEX_URL</Name>
      <Value>http://plex:32400</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_PLEX</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_TAUTULLI</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TAUTULLI_URL</Name>
      <Value>http://tautulli:8181</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_TAUTULLI</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_TRANSMISSION</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TRANSMISSION_URL</Name>
      <Value>http://transmission:6969</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_TRANSMISSION</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_QBITTORRENT</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>QBITTORRENT_URL</Name>
      <Value>http://qbittorrent:8080</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_QBITTORRENT</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_SABNZBD</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SABNZBD_URL</Name>
      <Value>http://sabnzbd:8080</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_SABNZBD</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_DELUGE</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>DELUGE_URL</Name>
      <Value>http://deluge:8112</Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_DELUGE</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>ENABLE_AUTH_OFFICE365</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_CLIENT_ID</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>OAUTH2_CLIENT_SECRET</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>OAUTH2_REDIRECT_URI</Name>
      <Value>https://yourdomain.com/oauth2callback</Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_ALLOWED_DOMAINS</Name>
      <Value>example.com</Value>
    </Variable>
    <Variable>
      <Name>OAUTH2_CRYPTO_PASSPHRASE</Name>
      <Value/>
    </Variable>
    <Variable>
      <Name>SSL_PROTOCOLS</Name>
      <Value>all -SSLv2 -SSLv3 -TLSv1 -TLSv1.1</Value>
    </Variable>
  </Environment>
  
  <Labels/>
  
  <!-- FORM CONFIGURATION - These appear in Unraid UI -->
  <Config Name="DOMAIN" Target="DOMAIN" Default="yourdomain.com" Mode="" Description="Domain Name (REQUIRED - e.g., example.com)" Type="Text" Display="always" Required="true" Mask="false"/>
  <Config Name="EMAIL" Target="EMAIL" Default="admin@example.com" Mode="" Description="Email for Let's Encrypt (REQUIRED)" Type="Text" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Australia/Melbourne" Mode="" Description="Timezone" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- SONARR -->
  <Config Name="[1/15] Enable Sonarr" Target="ENABLE_SONARR" Default="false" Mode="" Description="Sonarr - TV Show Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Sonarr URL" Target="SONARR_URL" Default="http://sonarr:8989" Mode="" Description="Backend URL (e.g., http://192.168.1.100:8989)" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Sonarr Icon URL" Target="ICON_URL_SONARR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- RADARR -->
  <Config Name="[2/15] Enable Radarr" Target="ENABLE_RADARR" Default="false" Mode="" Description="Radarr - Movie Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Radarr URL" Target="RADARR_URL" Default="http://radarr:7878" Mode="" Description="Backend URL (e.g., http://192.168.1.100:7878)" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Radarr Icon URL" Target="ICON_URL_RADARR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- WHISPARR -->
  <Config Name="[3/15] Enable Whisparr" Target="ENABLE_WHISPARR" Default="false" Mode="" Description="Whisparr - Adult Content" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Whisparr URL" Target="WHISPARR_URL" Default="http://whisparr:6969" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Whisparr Icon URL" Target="ICON_URL_WHISPARR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- JELLYFIN -->
  <Config Name="[4/15] Enable Jellyfin" Target="ENABLE_JELLYFIN" Default="false" Mode="" Description="Jellyfin - Media Streaming" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Jellyfin URL" Target="JELLYFIN_URL" Default="http://jellyfin:8096" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Jellyfin Icon URL" Target="ICON_URL_JELLYFIN" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- LIDARR -->
  <Config Name="[5/15] Enable Lidarr" Target="ENABLE_LIDARR" Default="false" Mode="" Description="Lidarr - Music Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Lidarr URL" Target="LIDARR_URL" Default="http://lidarr:8686" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Lidarr Icon URL" Target="ICON_URL_LIDARR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- READARR -->
  <Config Name="[6/15] Enable Readarr" Target="ENABLE_READARR" Default="false" Mode="" Description="Readarr - Book Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Readarr URL" Target="READARR_URL" Default="http://readarr:8787" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Readarr Icon URL" Target="ICON_URL_READARR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- PROWLARR -->
  <Config Name="[7/15] Enable Prowlarr" Target="ENABLE_PROWLARR" Default="false" Mode="" Description="Prowlarr - Indexer Manager" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Prowlarr URL" Target="PROWLARR_URL" Default="http://prowlarr:9696" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Prowlarr Icon URL" Target="ICON_URL_PROWLARR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- OVERSEERR -->
  <Config Name="[8/15] Enable Overseerr" Target="ENABLE_OVERSEERR" Default="false" Mode="" Description="Overseerr - Request Manager" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Overseerr URL" Target="OVERSEERR_URL" Default="http://overseerr:5055" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Overseerr Icon URL" Target="ICON_URL_OVERSEERR" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- EMBY -->
  <Config Name="[9/15] Enable Emby" Target="ENABLE_EMBY" Default="false" Mode="" Description="Emby - Media Streaming" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Emby URL" Target="EMBY_URL" Default="http://emby:8096" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Emby Icon URL" Target="ICON_URL_EMBY" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- PLEX -->
  <Config Name="[10/15] Enable Plex" Target="ENABLE_PLEX" Default="false" Mode="" Description="Plex - Media Streaming" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Plex URL" Target="PLEX_URL" Default="http://plex:32400" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Plex Icon URL" Target="ICON_URL_PLEX" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- TAUTULLI -->
  <Config Name="[11/15] Enable Tautulli" Target="ENABLE_TAUTULLI" Default="false" Mode="" Description="Tautulli - Analytics" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Tautulli URL" Target="TAUTULLI_URL" Default="http://tautulli:8181" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Tautulli Icon URL" Target="ICON_URL_TAUTULLI" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- TRANSMISSION -->
  <Config Name="[12/15] Enable Transmission" Target="ENABLE_TRANSMISSION" Default="false" Mode="" Description="Transmission - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Transmission URL" Target="TRANSMISSION_URL" Default="http://transmission:6969" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Transmission Icon URL" Target="ICON_URL_TRANSMISSION" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- QBITTORRENT -->
  <Config Name="[13/15] Enable qBittorrent" Target="ENABLE_QBITTORRENT" Default="false" Mode="" Description="qBittorrent - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="qBittorrent URL" Target="QBITTORRENT_URL" Default="http://qbittorrent:8080" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="qBittorrent Icon URL" Target="ICON_URL_QBITTORRENT" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- SABNZBD -->
  <Config Name="[14/15] Enable SABnzbd" Target="ENABLE_SABNZBD" Default="false" Mode="" Description="SABnzbd - Usenet Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="SABnzbd URL" Target="SABNZBD_URL" Default="http://sabnzbd:8080" Mode="" Description="Backend URL (e.g., http://192.168.9.13:8080)" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="SABnzbd Icon URL" Target="ICON_URL_SABNZBD" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- DELUGE -->
  <Config Name="[15/15] Enable Deluge" Target="ENABLE_DELUGE" Default="false" Mode="" Description="Deluge - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Deluge URL" Target="DELUGE_URL" Default="http://deluge:8112" Mode="" Description="Backend URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="Deluge Icon URL" Target="ICON_URL_DELUGE" Default="" Mode="" Description="Icon URL (leave blank for auto-generated)" Type="Text" Display="always" Required="false" Mask="false"/>
  
  <!-- OFFICE 365 AUTH -->
  <Config Name="Enable Office 365 Auth" Target="ENABLE_AUTH_OFFICE365" Default="false" Mode="" Description="Office 365/Azure AD Authentication" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="OAuth2 Client ID" Target="OAUTH2_CLIENT_ID" Default="" Mode="" Description="Azure AD Client ID" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="OAuth2 Client Secret" Target="OAUTH2_CLIENT_SECRET" Default="" Mode="" Description="Azure AD Client Secret" Type="Text" Display="always" Required="false" Mask="true"/>
  <Config Name="OAuth2 Redirect URI" Target="OAUTH2_REDIRECT_URI" Default="https://yourdomain.com/oauth2callback" Mode="" Description="Callback URL" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="OAuth2 Allowed Domains" Target="OAUTH2_ALLOWED_DOMAINS" Default="example.com" Mode="" Description="Allowed Domains (comma-separated)" Type="Text" Display="always" Required="false" Mask="false"/>
  <Config Name="OAuth2 Crypto Passphrase" Target="OAUTH2_CRYPTO_PASSPHRASE" Default="" Mode="" Description="Session Encryption Passphrase" Type="Text" Display="always" Required="false" Mask="true"/>
  
  <!-- PORTS -->
  <Config Name="HTTP Port" Target="HostPort" Default="80" Mode="tcp" Description="HTTP Port" Type="Port" Display="always" Required="false" Mask="false">80</Config>
  <Config Name="HTTPS Port" Target="HostPort" Default="443" Mode="tcp" Description="HTTPS Port" Type="Port" Display="always" Required="false" Mask="false">443</Config>
  
  <!-- VOLUMES -->
  <Config Name="Certificates Volume" Target="/etc/letsencrypt" Default="/mnt/user/appdata/apache-reverse-proxy/letsencrypt" Mode="rw" Description="SSL Certificates" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/apache-reverse-proxy/letsencrypt</Config>
  <Config Name="Logs Volume" Target="/var/log/apache2" Default="/mnt/user/appdata/apache-reverse-proxy/logs" Mode="rw" Description="Apache Logs" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/apache-reverse-proxy/logs</Config>
  <Config Name="HTML Volume" Target="/var/www/html" Default="/mnt/user/appdata/apache-reverse-proxy/html" Mode="rw" Description="HTML Dashboard" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/apache-reverse-proxy/html</Config>
</Container>
