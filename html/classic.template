<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 4.01//EN" "http://www.w3.org/TR/html4/strict.dtd">
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>@@DASHBOARD_NAME@@</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        :root {
            --bg-primary: #000;
            --bg-secondary: #1a1a1a;
            --bg-tertiary: rgba(74, 158, 255, 0.1);
            --text-primary: #fff;
            --text-secondary: #888;
            --text-accent: #4a9eff;
            --border-color: #444;
            --border-accent: rgba(74, 158, 255, 0.3);
        }

        [data-theme="light"] {
            --bg-primary: #f5f5f7;
            --bg-secondary: #ffffff;
            --bg-tertiary: rgba(74, 158, 255, 0.08);
            --text-primary: #1a1a1a;
            --text-secondary: #666;
            --text-accent: #0066cc;
            --border-color: #d0d0d0;
            --border-accent: rgba(74, 158, 255, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        [data-theme="light"] img {
            filter: invert(0.85) hue-rotate(180deg) brightness(0.95);
        }
        
        .header {
            background-color: var(--bg-secondary);
            padding: 15px 20px;
            border-bottom: 2px solid var(--border-color);
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            overflow: auto;
            min-height: 120px;
            gap: 30px;
        }

        .header-left {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .header-branding {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .datetime-box {
            flex-shrink: 0;
            background-color: rgba(74, 158, 255, 0.08);
            border: 1px solid rgba(74, 158, 255, 0.2);
            border-radius: 8px;
            padding: 8px 12px;
            text-align: center;
            min-width: auto;
        }

        .datetime-box .time {
            font-size: 20px;
            font-weight: bold;
            font-variant-numeric: tabular-nums;
            color: #4a9eff;
            margin-bottom: 2px;
            font-family: 'Courier New', monospace;
        }

        .datetime-box .date {
            font-size: 10px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .datetime-box .style-switcher {
            margin-top: 8px;
            padding-top: 6px;
            border-top: 1px solid rgba(74, 158, 255, 0.2);
            font-size: 9px;
        }
        
        .datetime-box .style-switcher a {
            color: #4a9eff;
            text-decoration: none;
            transition: all 0.2s;
        }
        
        .datetime-box .style-switcher a:hover {
            color: #6bb3ff;
            text-decoration: underline;
        }
        
        .menu-container {
            flex: 1;
            display: flex;
            justify-content: center;
        }
        
        .menu-table {
            width: 100%;
            border-collapse: collapse;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .menu-item {
            text-align: center;
            flex: 0 1 auto;
        }
        
        .menu-item a {
            display: inline-block;
            text-decoration: none;
            transition: transform 0.3s;
        }
        
        .menu-item a:hover {
            transform: scale(1.15);
        }
        
        .menu-item img {
            max-width: 120px;
            max-height: 100px;
            border: none;
            display: block;
        }
        
        .menu-item .label {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        
        .content {
            position: fixed;
            top: auto;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #000;
            border: none;
            width: 100%;
            height: calc(100% - 150px);
        }
        
        .welcome-screen {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            padding: 40px 20px;
            text-align: center;
        }
        
        .welcome-screen h1 {
            font-size: 2.5em;
            margin-bottom: 20px;
            color: #4a9eff;
        }
        
        .welcome-screen p {
            font-size: 1.1em;
            color: #aaa;
            margin-bottom: 10px;
            max-width: 600px;
        }
        
        .services-list {
            margin-top: 40px;
            text-align: left;
            display: inline-block;
        }
        
        .services-list h3 {
            color: #4a9eff;
            margin-bottom: 15px;
        }
        
        .services-list ul {
            list-style: none;
        }
        
        .services-list li {
            padding: 8px 0;
            color: #aaa;
            border-bottom: 1px solid #333;
        }
        
        .services-list li:last-child {
            border-bottom: none;
        }
        
        .services-list a {
            color: #4a9eff;
            text-decoration: none;
        }
        
        .services-list a:hover {
            text-decoration: underline;
        }

        .no-services {
            color: #ff6b6b;
            font-size: 1.2em;
            margin-top: 20px;
        }

        .sites-bar {
            background-color: var(--bg-secondary);
            border-top: 1px solid var(--border-color);
            padding: 10px 20px;
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            width: 100%;
            box-sizing: border-box;
            overflow-x: auto;
            overflow-y: hidden;
        }

        .site-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            text-decoration: none;
            padding: 6px;
            border-radius: 4px;
            border: 1px solid var(--border-color);
            background: var(--bg-primary);
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .site-link:hover {
            border-color: var(--text-accent);
            background: var(--bg-tertiary);
        }

        .site-icon {
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 2px;
            overflow: hidden;
        }

        .site-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 1px;
        }

        .site-code {
            display: none;
        }

        /* Responsive */
        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .header {
                min-height: auto;
                flex-direction: row;
                gap: 20px;
            }

            .header-left {
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }

            .datetime-box {
                min-width: auto;
                padding: 8px 12px;
            }

            .datetime-box .time {
                font-size: 18px;
            }
            
            .content {
                position: relative;
                height: auto;
                min-height: calc(100vh - 120px);
            }
            
            .welcome-screen h1 {
                font-size: 1.8em;
            }
            
            .menu-item img {
                max-width: 80px;
                max-height: 70px;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="header-left">
        <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;flex-shrink:0">
            <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:32px;height:32px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(58,160,224,.4))">
            <div id="dashboard-name" style="font-weight:600;font-size:14px;color:#cdd3dd;letter-spacing:0.1em">@@DASHBOARD_NAME@@</div>
        </a>
        <div class="datetime-box">
            <div class="time" id="currentTime">--:--</div>
            <div class="date" id="currentDate">Loading...</div>
            @@STYLE_SWITCHER@@
        </div>
    </div>
    <div class="menu-container">
        <table class="menu-table">
            <tr>
                @@MENU_ITEMS@@
            </tr>
        </table>
    </div>
    <div id="health-status" style="padding:15px 20px;border-top:1px solid #ddd;text-align:center;font-size:12px;color:#666;background:#f9f9f9">
        <span id="health-dot" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#4caf50;margin-right:6px;box-shadow:0 0 8px #4caf50"></span>
        <span id="health-text">Checking services...</span>
    </div>
</div>

<div class="sites-bar">
    @@SITES_ITEMS@@
</div>

<iframe name="Main" class="content" src="/@@DASHBOARD_LANDING@@" frameborder="0" scrolling="yes">
    <!-- Fallback content if iframe fails -->
    <div class="welcome-screen">
        <h1>🎬 Media Server Dashboard</h1>
        <p>Click a service above to access it</p>
        <p>All services are protected with HTTPS and accessible through this reverse proxy</p>
        <div class="services-list">
            <h3>Enabled Services:</h3>
            <ul>
                @@ENABLED_SERVICES_LIST@@
            </ul>
        </div>
    </div>
</iframe>

<noscript>
    <div class="welcome-screen">
        <h1>🎬 Media Server Dashboard</h1>
        <p>JavaScript is required for this interface</p>
    </div>
</noscript>

<script>
    function updateDateTime() {
        const now = new Date();
        
        // Format time as HH:MM
        const hours = String(now.getHours()).padStart(2, '0');
        const minutes = String(now.getMinutes()).padStart(2, '0');
        document.getElementById('currentTime').textContent = `${hours}:${minutes}`;
        
        // Format date
        const options = { weekday: 'short', month: 'short', day: 'numeric' };
        const dateStr = now.toLocaleDateString('en-US', options);
        document.getElementById('currentDate').textContent = dateStr;
    }
    
    // Update immediately
    updateDateTime();
    
    // Update every second
    setInterval(updateDateTime, 1000);
    
    // Service health check
    function checkServices() {
        const serviceLinks = Array.from(document.querySelectorAll('.menu-table a')).map(a => ({
            href: a.getAttribute('href'),
            text: a.textContent
        })).filter(s => s.href && s.href.startsWith('/'));
        
        if (serviceLinks.length === 0) return;
        
        const health = {};
        let checkCount = 0;
        
        serviceLinks.forEach(service => {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 10000);
            
            fetch(service.href, { method: 'GET', signal: controller.signal })
                .then(() => {
                    clearTimeout(timeoutId);
                    health[service.href] = 'online';
                })
                .catch(() => {
                    clearTimeout(timeoutId);
                    health[service.href] = 'offline';
                })
                .finally(() => {
                    checkCount++;
                    if (checkCount === serviceLinks.length) {
                        updateHealthDisplay(health, serviceLinks);
                    }
                });
        });
    }
    
    function updateHealthDisplay(health, services) {
        const offlineCount = Object.values(health).filter(s => s === 'offline').length;
        const onlineCount = services.length - offlineCount;
        const healthText = document.getElementById('health-text');
        const healthDot = document.getElementById('health-dot');
        
        if (offlineCount === 0) {
            healthText.textContent = `All ${services.length} services online`;
            healthDot.style.background = '#4caf50';
            healthDot.style.boxShadow = '0 0 8px #4caf50';
        } else {
            healthText.textContent = `${offlineCount} service${offlineCount > 1 ? 's' : ''} offline`;
            healthDot.style.background = '#ff6b6b';
            healthDot.style.boxShadow = '0 0 8px #ff6b6b';
        }
    }
    
    // Check services on load and every 30 seconds
    checkServices();
    setInterval(checkServices, 30000);

    // Hide sites bar if empty (check for child elements, not textContent)
    const sitesBar = document.querySelector('.sites-bar');
    if (sitesBar && sitesBar.children.length === 0) {
        sitesBar.style.display = 'none';
    }

    // Site link handling - open in new window
    document.querySelectorAll('.site-link').forEach(link => {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            window.open(this.href, '_blank');
        });
    });

    // Theme management
    (function() {
        const defaultTheme = '@@DASHBOARD_THEME@@' || 'dark';
        const savedTheme = localStorage.getItem('theme') || defaultTheme;
        document.documentElement.setAttribute('data-theme', savedTheme);

        const themeButton = document.getElementById('theme-toggle-classic');
        if (themeButton) {
            themeButton.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
            themeButton.addEventListener('click', function() {
                const current = document.documentElement.getAttribute('data-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
                themeButton.textContent = next === 'dark' ? '☀️' : '🌙';
            });
        }
    })();
</script>
</body>
</html>
