<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 4.01//EN" "http://www.w3.org/TR/html4/strict.dtd">
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <title>@@DASHBOARD_NAME@@</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background-color: #000;
            color: #fff;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }
        
        .header {
            background-color: #1a1a1a;
            padding: 15px 20px;
            border-bottom: 2px solid #444;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            overflow: auto;
            min-height: 120px;
            gap: 30px;
        }

        .header-left {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .header-branding {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .datetime-box {
            flex-shrink: 0;
            background-color: rgba(74, 158, 255, 0.1);
            border: 1px solid rgba(74, 158, 255, 0.3);
            border-radius: 8px;
            padding: 8px 12px;
            text-align: center;
            min-width: auto;
        }

        .datetime-box .time {
            font-size: 20px;
            font-weight: bold;
            font-variant-numeric: tabular-nums;
            color: #4a9eff;
            margin-bottom: 2px;
            font-family: 'Courier New', monospace;
        }

        .datetime-box .date {
            font-size: 10px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .datetime-box .style-switcher {
            margin-top: 8px;
            padding-top: 6px;
            border-top: 1px solid rgba(74, 158, 255, 0.2);
            font-size: 9px;
        }
        
        .datetime-box .style-switcher a {
            color: #4a9eff;
            text-decoration: none;
            transition: all 0.2s;
        }
        
        .datetime-box .style-switcher a:hover {
            color: #6bb3ff;
            text-decoration: underline;
        }
        
        .menu-container {
            flex: 1;
            display: flex;
            justify-content: center;
        }
        
        .menu-table {
            width: 100%;
            border-collapse: collapse;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .menu-item {
            text-align: center;
            flex: 0 1 auto;
        }
        
        .menu-item a {
            display: inline-block;
            text-decoration: none;
            transition: transform 0.3s;
        }
        
        .menu-item a:hover {
            transform: scale(1.15);
        }
        
        .menu-item img {
            max-width: 120px;
            max-height: 100px;
            border: none;
            display: block;
        }
        
        .menu-item .label {
            display: none !important;
            visibility: hidden !important;
            height: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        
        .content {
            position: fixed;
            top: auto;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #000;
            border: none;
            width: 100%;
            height: calc(100% - 150px);
        }
        
        .welcome-screen {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            padding: 40px 20px;
            text-align: center;
        }
        
        .welcome-screen h1 {
            font-size: 2.5em;
            margin-bottom: 20px;
            color: #4a9eff;
        }
        
        .welcome-screen p {
            font-size: 1.1em;
            color: #aaa;
            margin-bottom: 10px;
            max-width: 600px;
        }
        
        .services-list {
            margin-top: 40px;
            text-align: left;
            display: inline-block;
        }
        
        .services-list h3 {
            color: #4a9eff;
            margin-bottom: 15px;
        }
        
        .services-list ul {
            list-style: none;
        }
        
        .services-list li {
            padding: 8px 0;
            color: #aaa;
            border-bottom: 1px solid #333;
        }
        
        .services-list li:last-child {
            border-bottom: none;
        }
        
        .services-list a {
            color: #4a9eff;
            text-decoration: none;
        }
        
        .services-list a:hover {
            text-decoration: underline;
        }
        
        .no-services {
            color: #ff6b6b;
            font-size: 1.2em;
            margin-top: 20px;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .header {
                min-height: auto;
                flex-direction: row;
                gap: 20px;
            }

            .header-left {
                flex-direction: column;
                align-items: center;
                gap: 10px;
            }

            .datetime-box {
                min-width: auto;
                padding: 8px 12px;
            }

            .datetime-box .time {
                font-size: 18px;
            }
            
            .content {
                position: relative;
                height: auto;
                min-height: calc(100vh - 120px);
            }
            
            .welcome-screen h1 {
                font-size: 1.8em;
            }
            
            .menu-item img {
                max-width: 80px;
                max-height: 70px;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="header-left">
        <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;flex-shrink:0">
            <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:32px;height:32px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(58,160,224,.4))">
            <div id="dashboard-name" style="font-weight:600;font-size:14px;color:#cdd3dd;letter-spacing:0.1em">@@DASHBOARD_NAME@@</div>
        </a>
        <div class="datetime-box">
            <div class="time" id="currentTime">--:--</div>
            <div class="date" id="currentDate">Loading...</div>
            <div class="style-switcher" style="display:flex;gap:6px;justify-content:center">
                <a href="/" style="text-decoration:none;color:#4a9eff">Classic</a>
                <span style="color:#5d6575">|</span>
                <a href="/modern.html" style="text-decoration:none;color:#4a9eff">Modern</a>
                <span style="color:#5d6575">|</span>
                <a href="/sleek.html" style="text-decoration:none;color:#4a9eff">Sleek</a>
                <span style="color:#5d6575">|</span>
                <a href="/minimal.html" style="text-decoration:none;color:#4a9eff">Minimal</a>
            </div>
        </div>
    </div>
    <div class="menu-container">
        <table class="menu-table">
            <tr>
                @@MENU_ITEMS@@
            </tr>
        </table>
    </div>
    <div id="health-status" style="padding:15px 20px;border-top:1px solid #ddd;text-align:center;font-size:12px;color:#666;background:#f9f9f9">
        <span id="health-dot" style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#4caf50;margin-right:6px;box-shadow:0 0 8px #4caf50"></span>
        <span id="health-text">Checking services...</span>
    </div>
</div>

<iframe name="content" class="content" src="/@@DASHBOARD_LANDING@@" frameborder="0" scrolling="yes">
    <!-- Fallback content if iframe fails -->
    <div class="welcome-screen">
        <h1>🎬 Media Server Dashboard</h1>
        <p>Click a service above to access it</p>
        <p>All services are protected with HTTPS and accessible through this reverse proxy</p>
        <div class="services-list">
            <h3>Enabled Services:</h3>
            <ul>
                @@ENABLED_SERVICES_LIST@@
            </ul>
        </div>
    </div>
</iframe>

<noscript>
    <div class="welcome-screen">
        <h1>🎬 Media Server Dashboard</h1>
        <p>JavaScript is required for this interface</p>
    </div>
</noscript>

<script>
    function updateDateTime() {
        const now = new Date();
        
        // Format time as HH:MM
        const hours = String(now.getHours()).padStart(2, '0');
        const minutes = String(now.getMinutes()).padStart(2, '0');
        document.getElementById('currentTime').textContent = `${hours}:${minutes}`;
        
        // Format date
        const options = { weekday: 'short', month: 'short', day: 'numeric' };
        const dateStr = now.toLocaleDateString('en-US', options);
        document.getElementById('currentDate').textContent = dateStr;
    }
    
    // Update immediately
    updateDateTime();
    
    // Update every second
    setInterval(updateDateTime, 1000);
    
    // Service health check
    function checkServices() {
        const serviceLinks = Array.from(document.querySelectorAll('.menu-table a')).map(a => ({
            href: a.getAttribute('href'),
            text: a.textContent
        })).filter(s => s.href && s.href.startsWith('/'));
        
        if (serviceLinks.length === 0) return;
        
        const health = {};
        let checkCount = 0;
        
        serviceLinks.forEach(service => {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 10000);
            
            fetch(service.href, { method: 'GET', signal: controller.signal })
                .then(() => {
                    clearTimeout(timeoutId);
                    health[service.href] = 'online';
                })
                .catch(() => {
                    clearTimeout(timeoutId);
                    health[service.href] = 'offline';
                })
                .finally(() => {
                    checkCount++;
                    if (checkCount === serviceLinks.length) {
                        updateHealthDisplay(health, serviceLinks);
                    }
                });
        });
    }
    
    function updateHealthDisplay(health, services) {
        const offlineCount = Object.values(health).filter(s => s === 'offline').length;
        const onlineCount = services.length - offlineCount;
        const healthText = document.getElementById('health-text');
        const healthDot = document.getElementById('health-dot');
        
        if (offlineCount === 0) {
            healthText.textContent = `All ${services.length} services online`;
            healthDot.style.background = '#4caf50';
            healthDot.style.boxShadow = '0 0 8px #4caf50';
        } else {
            healthText.textContent = `${offlineCount} service${offlineCount > 1 ? 's' : ''} offline`;
            healthDot.style.background = '#ff6b6b';
            healthDot.style.boxShadow = '0 0 8px #ff6b6b';
        }
    }
    
    // Check services on load and every 30 seconds
    checkServices();
    setInterval(checkServices, 30000);
</script>
</body>
</html>
