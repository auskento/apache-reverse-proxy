<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>@@DASHBOARD_NAME@@</title>
<script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/react.production.min.js"></script>
<script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/react-dom.production.min.js"></script>
<script src="support.js"></script>
<script>
window.getCoordinates = function() { return { x: 0, y: 0, width: 0, height: 0 }; };
window.ClientData = window.ClientData || {};
window.ClientData.update = function() {};
if (typeof window !== 'undefined' && window.parent && window.parent !== window) {
  try {
    window.parent.getCoordinates = window.parent.getCoordinates || function() { return { x: 0, y: 0, width: 0, height: 0 }; };
    window.parent.ClientData = window.parent.ClientData || {};
    window.parent.ClientData.update = window.parent.ClientData.update || function() {};
  } catch(e) {}
}
</script>
</head>
<body>
<x-dc>
<helmet>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-primary: #08090c;
    --bg-secondary: rgba(20, 23, 30, 0.72);
    --bg-tertiary: rgba(255, 255, 255, 0.05);
    --bg-gradient-start: rgba(20, 23, 30, 0.72);
    --bg-gradient-end: rgba(12, 14, 19, 0.72);
    --text-primary: #e9ecf2;
    --text-secondary: #8b93a3;
    --text-tertiary: #5d6575;
    --text-accent: #cdd3dd;
    --text-bright: #f4f6fa;
    --text-light: #eef1f6;
    --text-muted: #828b9c;
    --text-dim: #4b5263;
    --text-link: #4a9eff;
    --border-color: rgba(255, 255, 255, 0.06);
    --border-light: rgba(255, 255, 255, 0.07);
    --border-hover: rgba(255, 255, 255, 0.09);
  }

  [data-theme="light"] {
    --bg-primary: #f5f5f7;
    --bg-secondary: rgba(245, 245, 247, 0.95);
    --bg-tertiary: rgba(0, 0, 0, 0.05);
    --bg-gradient-start: rgba(250, 250, 252, 0.95);
    --bg-gradient-end: rgba(240, 240, 242, 0.95);
    --text-primary: #1a1a1a;
    --text-secondary: #6b7280;
    --text-tertiary: #9ca3af;
    --text-accent: #374151;
    --text-bright: #000000;
    --text-light: #1f2937;
    --text-muted: #6b7280;
    --text-dim: #9ca3af;
    --text-link: #0066cc;
    --border-color: rgba(0, 0, 0, 0.08);
    --border-light: rgba(0, 0, 0, 0.1);
    --border-hover: rgba(0, 0, 0, 0.15);
  }

  *{box-sizing:border-box}
  html,body{margin:0;height:100%}
  body{background:var(--bg-primary);overflow:hidden}
  [data-theme="light"] img{filter:invert(0.85) hue-rotate(180deg) brightness(0.95)}
  ::-webkit-scrollbar{width:9px}
  ::-webkit-scrollbar-thumb{background:rgba(255,255,255,.09);border-radius:9px}
  ::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.16)}
  [data-theme="light"] ::-webkit-scrollbar-thumb{background:rgba(0,0,0,.12)}
  [data-theme="light"] ::-webkit-scrollbar-thumb:hover{background:rgba(0,0,0,.18)}
  @keyframes floatGlow{0%,100%{opacity:.55}50%{opacity:.95}}
  .site-link{display:flex;flex-direction:column;align-items:center;gap:4px;padding:10px;border-radius:9px;text-decoration:none;color:inherit;background:var(--bg-tertiary);border:1px solid var(--border-color);transition:all 0.2s;cursor:pointer}
  .site-link:hover{background:var(--bg-secondary);border-color:var(--border-hover)}
  .site-link:active{transform:scale(0.95)}
  .site-icon{width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:6px;overflow:hidden;background:var(--bg-primary)}
  .site-icon img{width:100%;height:100%;object-fit:contain;padding:2px}
  .site-code{display:none}
</style>
</helmet>

<div style="display:flex;height:100vh;width:100vw;font-family:'Inter',system-ui,sans-serif;color:var(--text-primary);background:radial-gradient(1200px 700px at 18% -10%,rgba(58,160,224,.10),transparent 60%),radial-gradient(900px 600px at 100% 110%,rgba(46,205,111,.07),transparent 55%),var(--bg-primary);overflow:hidden">

  <aside style="width:320px;flex:none;height:100%;display:flex;flex-direction:column;background:linear-gradient(180deg,var(--bg-gradient-start),var(--bg-gradient-end));backdrop-filter:blur(18px);border-right:1px solid var(--border-light)">

    <div style="padding:26px 26px 20px 26px;border-bottom:1px solid var(--border-color)">
      <a href="/" style="display:flex;align-items:center;gap:11px;margin-bottom:22px;text-decoration:none;cursor:pointer">
        <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:34px;height:34px;border-radius:9px;object-fit:contain;box-shadow:0 4px 16px rgba(58,160,224,.4)">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;letter-spacing:.14em;font-size:13px;color:var(--text-accent)">@@DASHBOARD_NAME@@</div>
      </a>
      <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:25px;line-height:1.15;letter-spacing:-.01em;color:var(--text-bright)">{{ greeting }}</div>
      <div style="display:flex;align-items:baseline;gap:10px;margin-top:7px">
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:500;font-size:15px;color:var(--text-secondary);font-variant-numeric:tabular-nums">{{ clock }}</div>
        <div style="font-size:13px;color:var(--text-tertiary)">{{ today }}</div>
      </div>
    </div>

    <nav style="flex:1;overflow-y:auto;overflow-x:hidden;padding:8px 16px 22px 16px">
      <sc-for list="{{ groups[0].items }}" as="app">
        <button onClick="{{ app.open }}" style="{{ app.style }}" style-hover="{{ app.hoverStyle }}">
          <span style="width:46px;height:46px;flex:none;border-radius:12px;background:var(--bg-tertiary);display:flex;align-items:center;justify-content:center;overflow:hidden;box-shadow:inset 0 0 0 1px var(--border-color)">
            {{ app.iconEl }}
          </span>
          <span style="flex:1;min-width:0;text-align:left">
            <span style="display:block;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:15px;color:var(--text-light)">{{ app.name }}</span>
            <span style="display:block;font-size:12.5px;color:var(--text-muted);margin-top:1px">{{ app.desc }}</span>
          </span>
          <span style="{{ app.dotStyle }}"></span>
        </button>
      </sc-for>
    </nav>

    <div style="padding:14px 26px;border-top:1px solid var(--border-color)">
      @@STYLE_SWITCHER@@
    </div>
  </aside>

  <main style="flex:1;min-width:0;position:relative">
    <iframe name="Main" ref="{{ frameRef }}" title="App" src="/@@DASHBOARD_LANDING@@" style="position:absolute;inset:0;width:100%;height:100%;border:0;background:var(--bg-primary)"></iframe>

    <sc-if value="{{ showWelcome }}" hint-placeholder-val="{{ true }}">
      <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;background:radial-gradient(900px 600px at 50% 30%,rgba(58,160,224,.08),transparent 60%),#0b0d11">
        <a href="/" style="display:flex;align-items:center;justify-content:center;text-decoration:none;cursor:pointer">
          <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:80px;height:80px;margin-bottom:26px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(58,160,224,.3))">
        </a>
        <div style="font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:27px;color:#f4f6fa;letter-spacing:-.01em">Welcome back</div>
        <div style="font-size:15px;color:#828b9c;margin-top:10px;max-width:380px;line-height:1.55">Pick a service from the sidebar to open it here. Your library, downloads and indexers — all in one place.</div>
      </div>
    </sc-if>
  </main>

  <aside style="width:120px;flex:none;height:100%;display:flex;flex-direction:column;background:linear-gradient(180deg,var(--bg-gradient-start),var(--bg-gradient-end));backdrop-filter:blur(18px);border-left:1px solid var(--border-light);overflow-y:auto;overflow-x:hidden;padding:16px 8px">
    <div style="display:flex;flex-direction:column;gap:8px">
      @@SITES_ITEMS@@
    </div>
  </aside>
</div>
</x-dc>

<script type="text/x-dc" data-dc-script>
class Component extends DCLogic {
  state = { now: new Date(), activeId: null, showWelcome: true, serviceHealth: {} };

  componentDidMount() {
    this._t = setInterval(() => this.setState({ now: new Date() }), 1000);

    // Handle iframe loading with LANDING page
    if (this._frame) {
      // If iframe has a src, hide welcome screen initially
      if (this._frame.src && this._frame.src !== 'about:blank') {
        this.setState({ showWelcome: false });
      }

      // Hide welcome screen when iframe loads successfully
      this._frame.addEventListener('load', () => {
        this.setState({ showWelcome: false });
        // Inject iframe compatibility stubs and error handler for services like qBittorrent
        try {
          const iframeWin = this._frame.contentWindow;
          if (iframeWin) {
            // Define compatibility stubs
            iframeWin.getCoordinates = function() { return { x: 0, y: 0, width: 0, height: 0 }; };
            iframeWin.ClientData = { update: function() {} };

            // Suppress harmless errors from embedded applications
            const originalError = iframeWin.onerror;
            iframeWin.onerror = function(msg, url, line, col, error) {
              if (msg && (msg.includes('ClientData') || msg.includes('getCoordinates'))) {
                return true; // Suppress error
              }
              return originalError ? originalError(msg, url, line, col, error) : false;
            };
          }
        } catch(e) {}
      });

      // Show welcome screen if iframe fails to load
      this._frame.addEventListener('error', () => {
        this.setState({ showWelcome: true });
      });
    }
  }
  
  componentWillUnmount() {
    clearInterval(this._t);
    if (this._frame) {
      this._frame.removeEventListener('load', this._onIframeLoad);
      this._frame.removeEventListener('error', this._onIframeError);
    }
  }

  navigate(app) {
    if (app.popup) {
      window.open(app.href, app.name, 'resizable=no,status=no,location=no,toolbar=no,menubar=no,scrollbars=no');
      return;
    }
    this.setState({ activeId: app.id, showWelcome: false });
    if (this._frame) {
      this._frame.src = app.href;
    }
  }

  renderVals() {
    const now = this.state.now;
    const h = now.getHours();
    const greeting = h < 5 ? 'Burning the midnight oil' : h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening';
    const clock = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const today = now.toLocaleDateString([], { weekday: 'long', month: 'short', day: 'numeric' });

    const raw = [
      @@SERVICES_ARRAY@@
    ];

    const orderCodes = @@DASHBOARD_ORDER@@;

    const mk = (app) => {
      const active = this.state.activeId === app.id;
      return {
        ...app,
        open: () => this.navigate(app),
        iconEl: React.createElement('img', { src: app.icon, alt: app.name, style: { width: 34, height: 34, objectFit: 'contain' } }),
        style: `display:flex;align-items:center;gap:14px;width:100%;text-align:left;cursor:pointer;border:0;border-radius:14px;padding:11px 12px;margin-top:6px;font-family:inherit;transition:background .16s,box-shadow .16s,transform .12s;background:${active ? 'rgba(255,255,255,.08)' : 'transparent'};box-shadow:${active ? `inset 0 0 0 1px ${app.accent}55, 0 6px 22px -8px ${app.accent}66` : 'inset 0 0 0 1px transparent'}`,
        hoverStyle: `background:rgba(255,255,255,.06);box-shadow:inset 0 0 0 1px ${app.accent}40;transform:translateX(2px)`,
        dotStyle: `width:8px;height:8px;flex:none;border-radius:50%;background:${app.accent};box-shadow:0 0 9px ${app.accent};opacity:${active ? 1 : .65}`,
      };
    };

    const items = orderCodes.map(code => raw.find(a => a.id === code)).filter(a => a).map(mk);
    const groups = [{ items }];

    return {
      greeting, clock, today, groups,
      showWelcome: this.state.showWelcome,
      frameRef: (el) => { this._frame = el; },
    };
  }
}
</script>
<script>
  // Theme management
  (function() {
    const themeValue = '@@DASHBOARD_THEME@@';
    const defaultTheme = (themeValue && themeValue !== '@@DASHBOARD_THEME@@') ? themeValue : 'dark';
    const savedTheme = localStorage.getItem('theme') || defaultTheme;
    document.documentElement.setAttribute('data-theme', savedTheme);

    const themeButton = document.getElementById('theme-toggle-modern');
    if (themeButton) {
      themeButton.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
      themeButton.addEventListener('click', function() {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        themeButton.textContent = next === 'dark' ? '☀️' : '🌙';
      });
    }
  });

  // Hide sites sidebar if empty
  const sitesSidebar = document.querySelector('aside:last-of-type');
  if (sitesSidebar && sitesSidebar.textContent.trim() === '') {
    sitesSidebar.style.display = 'none';
  }

  // Site link handling - open in new window
  document.querySelectorAll('.site-link').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      window.open(this.href, '_blank');
    });
  });
</script>
</body>
</html>
