<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>@@DASHBOARD_NAME@@</title>
</head>
<body style="margin:0;height:100%;background:#08090c;font-family:system-ui,sans-serif">
<div style="display:flex;height:100vh;width:100vw;color:#e9ecf2;background:radial-gradient(1200px 700px at 18% -10%,rgba(58,160,224,.10),transparent 60%),radial-gradient(900px 600px at 100% 110%,rgba(46,205,111,.07),transparent 55%),#08090c;overflow:hidden">

  <aside id="sidebar" style="display:flex;flex-direction:column;align-items:center;gap:24px;padding:40px 30px;max-height:100%;overflow-y:auto;flex:none;border-right:1px solid rgba(255,255,255,.05)">

    <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
      <a href="/" style="display:flex;align-items:center;justify-content:center;text-decoration:none;cursor:pointer">
        <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:48px;height:48px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(58,160,224,.4))">
      </a>
      <div style="text-align:center">
        <div style="font-size:13px;color:#6b7385;letter-spacing:.08em">MEDIA</div>
      </div>
    </div>

    <nav id="services-nav" style="display:flex;flex-direction:column;gap:20px;align-items:center">
      <!-- Services buttons injected here -->
    </nav>

    <div style="width:1px;height:20px;background:rgba(255,255,255,.1);margin-top:auto"></div>

    <div id="health-status" style="text-align:center;font-size:11px;color:#5d6575">
      <span id="health-dot" style="display:block;width:8px;height:8px;border-radius:50%;background:#2ecd6f;margin:0 auto 6px;box-shadow:0 0 8px #2ecd6f;animation:floatGlow 2.6s ease-in-out infinite"></span>
      <span id="health-text">Checking...</span>
    </div>

    <div style="width:100%;border-top:1px solid rgba(255,255,255,.1);padding-top:20px;margin-top:20px">
      <div id="user-info" style="text-align:center;font-size:12px;color:#a0aab8;margin-bottom:12px">
        <div id="user-name" style="font-weight:600;color:#e9ecf2">Loading...</div>
        <div style="font-size:11px;color:#6b7385;margin-top:4px" id="user-email"></div>
      </div>
      <button id="logout-btn" style="width:100%;padding:8px 12px;background:rgba(255,107,107,.15);color:#ff6b6b;border:1px solid rgba(255,107,107,.3);border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;transition:all .2s;display:none" onmouseover="this.style.background='rgba(255,107,107,.25)'" onmouseout="this.style.background='rgba(255,107,107,.15)'">
        Sign Out
      </button>
    </div>

  </aside>

  <main style="flex:1;min-width:0;position:relative;display:flex;flex-direction:column">
    <div id="top-bar" style="padding:12px 20px;border-bottom:1px solid rgba(255,255,255,.05);background:rgba(8,9,12,.5);display:none;align-items:center;justify-content:space-between">
      <div id="current-service" style="font-size:14px;font-weight:600;color:#e9ecf2"></div>
      <button id="close-service" style="padding:4px 12px;background:rgba(255,107,107,.1);color:#ff6b6b;border:1px solid rgba(255,107,107,.2);border-radius:6px;cursor:pointer;font-size:12px;transition:all .2s" onmouseover="this.style.background='rgba(255,107,107,.2)'" onmouseout="this.style.background='rgba(255,107,107,.1)'">
        Close
      </button>
    </div>

    <iframe id="content-frame" name="Main" title="App" src="/@@LANDING@@" style="flex:1;width:100%;border:0;background:#0b0d11;display:none"></iframe>

    <div id="welcome-screen" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;background:radial-gradient(900px 600px at 50% 30%,rgba(58,160,224,.08),transparent 60%),#0b0d11">
      <img src="@@DASHBOARD_ICON@@" alt="Dashboard" style="width:80px;height:80px;margin-bottom:26px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(58,160,224,.3))">
      <div style="font-weight:600;font-size:27px;color:#f4f6fa;letter-spacing:-.01em">Welcome back</div>
      <div style="font-size:15px;color:#828b9c;margin-top:10px;max-width:380px;line-height:1.55">Pick a service from the sidebar to open it here. Your library, downloads and indexers — all in one place.</div>
    </div>
  </main>
</div>

<style>
  @keyframes floatGlow { 0%,100%{opacity:.55} 50%{opacity:.95} }
  .service-btn {
    cursor:pointer;
    border:0;
    padding:0;
    background:transparent;
    transition:transform .2s,filter .2s;
    border-radius:14px;
  }
  .service-btn:hover {
    transform:scale(1.1);
    filter:brightness(1.3);
  }
  .service-icon {
    width:60px;
    height:60px;
    flex:none;
    border-radius:14px;
    background:rgba(255,255,255,.05);
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
    box-shadow:inset 0 0 0 1px rgba(255,255,255,.08);
    transition:box-shadow .2s;
    border:2px solid transparent;
  }
  .service-btn:hover .service-icon {
    box-shadow:inset 0 0 0 2px var(--accent), 0 0 16px var(--accent)66;
  }
  .service-btn.active .service-icon {
    box-shadow:inset 0 0 0 2px var(--accent), 0 0 16px var(--accent)66;
  }
  .service-icon img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
</style>

<script>
  const SERVICES = @@SERVICES_ARRAY@@;
  const frame = document.getElementById('content-frame');
  const welcome = document.getElementById('welcome-screen');
  const topBar = document.getElementById('top-bar');
  const currentServiceName = document.getElementById('current-service');
  const closeBtn = document.getElementById('close-service');
  const nav = document.getElementById('services-nav');
  const logoutBtn = document.getElementById('logout-btn');
  const userNameEl = document.getElementById('user-name');
  const userEmailEl = document.getElementById('user-email');
  let activeId = null;

  function navigate(app) {
    if (app.popup) {
      window.open(app.href, app.name, 'resizable=no,status=no,location=no,toolbar=no,menubar=no,scrollbars=no');
      return;
    }

    // Hide welcome, show frame and top bar
    welcome.style.display = 'none';
    topBar.style.display = 'flex';
    frame.style.display = 'block';

    // Update active state
    document.querySelectorAll('.service-btn').forEach(btn => {
      if (btn.dataset.id === app.id) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    currentServiceName.textContent = app.name;
    activeId = app.id;
    frame.src = app.href;
  }

  function closeService() {
    welcome.style.display = 'flex';
    topBar.style.display = 'none';
    frame.style.display = 'none';
    frame.src = '';
    document.querySelectorAll('.service-btn').forEach(btn => {
      btn.classList.remove('active');
    });
    activeId = null;
  }

  closeBtn.onclick = closeService;

  // Render services
  SERVICES.forEach(app => {
    const btn = document.createElement('button');
    btn.className = 'service-btn';
    btn.dataset.id = app.id;
    btn.title = app.name;
    btn.style.setProperty('--accent', app.accent);
    btn.onclick = () => navigate(app);

    btn.innerHTML = `
      <div class="service-icon">
        <img src="${app.icon}" alt="${app.name}" />
      </div>
    `;

    nav.appendChild(btn);
  });

  // Load user info from OAuth session
  async function loadUserInfo() {
    try {
      // Try to get user info - this endpoint would be provided by OAuth implementation
      const response = await fetch('/api/user', { credentials: 'include' });
      if (response.ok) {
        const user = await response.json();
        userNameEl.textContent = user.name || user.username || 'User';
        if (user.email) {
          userEmailEl.textContent = user.email;
        }
        logoutBtn.style.display = 'block';
      }
    } catch (e) {
      // OAuth info not available - hide user section
      userNameEl.parentElement.style.display = 'none';
    }
  }

  // Handle logout
  logoutBtn.onclick = () => {
    fetch('/auth/logout', { method: 'POST', credentials: 'include' })
      .then(() => {
        window.location.href = '/';
      })
      .catch(() => {
        window.location.href = '/';
      });
  };

  // Service health check
  function checkServices() {
    const health = {};
    let checkCount = 0;

    SERVICES.forEach(app => {
      if (app.popup) {
        health[app.id] = 'online';
        checkCount++;
        if (checkCount === SERVICES.length) {
          updateHealthDisplay(health);
        }
        return;
      }

      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 10000);

      fetch(app.href, { method: 'HEAD', signal: controller.signal, credentials: 'include' })
        .then(() => {
          clearTimeout(timeoutId);
          health[app.id] = 'online';
        })
        .catch(() => {
          clearTimeout(timeoutId);
          health[app.id] = 'offline';
        })
        .finally(() => {
          checkCount++;
          if (checkCount === SERVICES.length) {
            updateHealthDisplay(health);
          }
        });
    });
  }

  function updateHealthDisplay(health) {
    const offlineCount = Object.values(health).filter(s => s === 'offline').length;
    const healthText = document.getElementById('health-text');
    const healthDot = document.getElementById('health-dot');

    if (offlineCount === 0) {
      healthText.textContent = 'Online';
      healthDot.style.background = '#2ecd6f';
      healthDot.style.boxShadow = '0 0 8px #2ecd6f';
    } else {
      healthText.textContent = `${offlineCount} offline`;
      healthDot.style.background = '#ff6b6b';
      healthDot.style.boxShadow = '0 0 8px #ff6b6b';
    }
  }

  // Initialize
  loadUserInfo();
  checkServices();
  setInterval(checkServices, 30000);
</script>
</body>
</html>
