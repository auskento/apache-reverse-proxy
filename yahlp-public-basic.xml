  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="" Mode="" Description="Format: user1:pass1|user2:pass2 (for AUTHTYPE=basic only)" Type="Variable" Display="always" Required="false" Mask="true"/>

