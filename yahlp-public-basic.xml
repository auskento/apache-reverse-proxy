  <Config Name="Domain" Target="DOMAIN" Default="yourdomain.com" Mode="" Description="Your domain name (required for Let's Encrypt SSL - public mode only)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Email" Target="EMAIL" Default="admin@example.com" Mode="" Description="Email for Let's Encrypt notifications (public mode only)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Australia/Melbourne" Mode="" Description="Timezone for logs and cron jobs (e.g., UTC, US/Eastern, Europe/London)" Type="Variable" Display="always" Required="false" Mask="false"/>

  <!-- DASHBOARD CUSTOMIZATION -->
  <Config Name="Dashboard Style" Target="STYLE" Default="modern" Mode="" Description="Dashboard theme: modern (recommended), classic, sleek, or minimal" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Theme" Target="DASHBOARD_THEME" Default="dark" Mode="" Description="Color scheme: dark or light" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="Media Server" Mode="" Description="Custom dashboard title shown in header" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Icon" Target="DASHBOARD_ICON" Default="/icons/yahlp.png" Mode="" Description="Icon path (place custom icons in html/icons/)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Landing" Target="DASHBOARD_LANDING" Default="" Mode="" Description="Default page on startup (e.g., sonarr, radarr/calendar, plex/web). Leave blank for welcome screen" Type="Variable" Display="always" Required="false" Mask="false"/>
