<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>YAHLP</Name>
  <Repository>auskento/yahlp:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/yahlp</Support>
  <Project>https://github.com/auskento/yahlp</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp/main/yahlp-public-basic.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/yahlp/main/yahlp-150.png</Icon>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>YAHLP - Yet Another HomeLab Portal. Unified media server dashboard with 17 services, 4 dashboard styles, flexible authentication (None, Basic, Entra ID, Google OAuth), and automatic HTTPS.</Description>
  <Overview>YAHLP (Yet Another HomeLab Portal) - Unified Media Server Dashboard&#13;&#13;A production-ready reverse proxy system for managing 17+ homelab applications with automatic HTTPS, flexible authentication, and customizable dashboards.&#13;&#13;Features:&#13;- Public mode: Automatic HTTPS with Let's Encrypt SSL certificates&#13;- Private mode: Internal-only deployment without certificate generation&#13;- Reverse proxy for 17 different services&#13;- Responsive web dashboard with 4 customizable styles: classic, modern, sleek, minimal&#13;- Light/dark theme toggle with localStorage persistence&#13;- Dashboard customization: custom title, icon, and default landing page&#13;- Four authentication options: None, Basic Auth, Entra ID (Microsoft), or Google OAuth2&#13;- Custom service icons with smart light/dark mode adaptation&#13;- Configurable service category ordering&#13;- Torrent/Usenet site links with favicon caching&#13;&#13;Supported Services (17):&#13;CONTENT: Sonarr, Radarr, Lidarr, Whisparr&#13;SEARCH: Seerr, Prowlarr, Bazarr&#13;USENET: SABnzbd, NZBGet, NZBHydra&#13;TORRENTS: Deluge, Transmission, qBittorrent&#13;MEDIA: Emby, Plex, Jellyfin, Tautulli&#13;&#13;Dashboard Styles:&#13;- Classic: Traditional sidebar menu&#13;- Modern: React-based with full features (recommended)&#13;- Sleek: Compact sidebar with gradient styling&#13;- Minimal: Single-column minimal design&#13;&#13;Documentation: https://github.com/auskento/yahlp</Overview>
  <Networking>
    <Mode>br0</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

